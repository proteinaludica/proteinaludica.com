+<!-- ═══════════════════════════════════════════════════════════════════
+     INTERNATO MGF — Fase 1 (esqueleto) — JS
+     Não toca em nada do v9.5 SOAP. Auto-save dx_autosave_v1 inalterado.
+     Toggle, tabs, perfil, rubrica OM. Namespace localStorage dx_int_*.
+     ═══════════════════════════════════════════════════════════════════ -->
+<script>
+(function(){
+  'use strict';
+
+  var KEY_MODE       = 'dx_int_mode';
+  var KEY_TAB        = 'dx_int_tab';
+  var KEY_PROF_INIT  = 'dx_int_profile_initials';
+  var KEY_PROF_YEAR  = 'dx_int_profile_year';
+  var KEY_PROF_USF   = 'dx_int_profile_usf';
+  var KEY_AVAL_INSTR = 'dx_int_aval_current_instr';
+  var KEY_AVAL_SCORE = 'dx_int_aval_current_score';
+  var KEY_AVAL_NOTES = 'dx_int_aval_current_notes';
+  var KEY_AVAL_LIST  = 'dx_int_avaliacoes';
+
+  function lsGet(k, dflt){ try { var v = localStorage.getItem(k); return v == null ? dflt : v; } catch(e){ return dflt; } }
+  function lsSet(k, v){ try { localStorage.setItem(k, v); } catch(e){} }
+
+  // ── Modo (SOAP / Internato) ─────────────────────────────────────────
+  window.dxModeSet = function(mode){
+    if (mode !== 'soap' && mode !== 'internato') return;
+    var b = document.body;
+    if (mode === 'internato') b.classList.add('dx-mode-internato');
+    else b.classList.remove('dx-mode-internato');
+    lsSet(KEY_MODE, mode);
+    var tog = document.getElementById('hdr-mode-tog');
+    if (tog) {
+      tog.querySelectorAll('button').forEach(function(btn){
+        var on = btn.dataset.mode === mode;
+        btn.classList.toggle('on', on);
+        btn.setAttribute('aria-selected', on ? 'true' : 'false');
+      });
+    }
+    var sub = document.getElementById('hdr-sub');
+    if (sub) sub.textContent = mode === 'internato' ? 'Internato MGF' : 'SOAP';
+  };
+
+  // ── Tabs internas ───────────────────────────────────────────────────
+  var INT_TABS = ['log','aval','dia','jc'];
+  window.dxIntTab = function(t){
+    if (INT_TABS.indexOf(t) < 0) return;
+    INT_TABS.forEach(function(k){
+      var tab = document.getElementById('tab-int-' + k);
+      var pan = document.getElementById('pi-' + k);
+      var on = (k === t);
+      if (tab) {
+        tab.classList.toggle('on', on);
+        tab.setAttribute('aria-selected', on ? 'true' : 'false');
+        tab.setAttribute('tabindex', on ? '0' : '-1');
+      }
+      if (pan) pan.classList.toggle('on', on);
+    });
+    lsSet(KEY_TAB, t);
+  };
+
+  // ── Perfil interno (1 perfil por navegador, namespacing dx_int_profile_*) ──
+  window.dxIntProfileSave = function(){
+    var i = (document.getElementById('int-prof-init')||{}).value || '';
+    var y = (document.getElementById('int-prof-year')||{}).value || '';
+    var u = (document.getElementById('int-prof-usf')||{}).value || '';
+    lsSet(KEY_PROF_INIT, i.toUpperCase().slice(0,5));
+    lsSet(KEY_PROF_YEAR, y);
+    lsSet(KEY_PROF_USF, u);
+  };
+  function dxIntProfileLoad(){
+    var ie = document.getElementById('int-prof-init');
+    var ye = document.getElementById('int-prof-year');
+    var ue = document.getElementById('int-prof-usf');
+    if (ie) ie.value = lsGet(KEY_PROF_INIT, '');
+    if (ye) ye.value = lsGet(KEY_PROF_YEAR, '');
+    if (ue) ue.value = lsGet(KEY_PROF_USF, '');
+  }
+
+  // ── Avaliações OM (Mini-CEX / DOPS / CbD / MSF + escala 1-6) ────────
+  window.dxOMSelect = function(btn, dim, val){
+    var fld = btn.closest && btn.closest('.om-fld');
+    if (!fld) return;
+    fld.querySelectorAll('.om-scale-btn').forEach(function(b){
+      b.classList.remove('on');
+      b.setAttribute('aria-checked', 'false');
+    });
+    btn.classList.add('on');
+    btn.setAttribute('aria-checked', 'true');
+    if (dim === 'instr') lsSet(KEY_AVAL_INSTR, val);
+    else if (dim === 'score') lsSet(KEY_AVAL_SCORE, val);
+  };
+
+  function dxOMRestore(){
+    var instr = lsGet(KEY_AVAL_INSTR, '');
+    var score = lsGet(KEY_AVAL_SCORE, '');
+    var notes = lsGet(KEY_AVAL_NOTES, '');
+    document.querySelectorAll('#pi-aval .om-scale-btn').forEach(function(b){
+      var oc = b.getAttribute('onclick') || '';
+      var m = oc.match(/'(instr|score)','([^']+)'/);
+      if (!m) return;
+      if ((m[1] === 'instr' && m[2] === instr) || (m[1] === 'score' && m[2] === score)) {
+        b.classList.add('on');
+        b.setAttribute('aria-checked', 'true');
+      }
+    });
+    var ne = document.getElementById('int-aval-notes');
+    if (ne) {
+      ne.value = notes;
+      ne.addEventListener('input', function(){ lsSet(KEY_AVAL_NOTES, ne.value); });
+    }
+  }
+
+  function dxIntAvalCount(){
+    var n = 0;
+    try { n = (JSON.parse(lsGet(KEY_AVAL_LIST, '[]')) || []).length; } catch(e){}
+    var el = document.getElementById('int-aval-count');
+    if (el) el.textContent = n ? (n + ' avaliações guardadas') : '';
+  }
+
+  window.dxOMSave = function(){
+    var instr = lsGet(KEY_AVAL_INSTR, '');
